{
	"name": "@cathodecube/slate",
	"version": "0.1.0",
	"type": "module",
	"main": "./src/index.ts",
	"bin": {
		"slate": "src/cli/main.ts"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"files": [
		"src",
		"README.md"
	],
	"scripts": {
		"start": "bun run src/cli/main.ts",
		"typecheck": "tsc --noEmit",
		"format": "find src test -name '*.ts' -print0 | xargs -0 biome check --write --unsafe",
		"test": "vitest run"
	},
	"description": "A minimal, agent-native issue tracker",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cathodecube/slate.git"
	},
	"bugs": {
		"url": "https://github.com/cathodecube/slate/issues"
	},
	"homepage": "https://github.com/cathodecube/slate#readme",
	"author": "Cathode Cube",
	"license": "Apache-2.0",
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"lefthook": "^2.1.6",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"gray-matter": "^4.0.3",
		"zod": "^4.4.3"
	}
}
