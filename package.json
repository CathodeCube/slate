{
	"name": "slate",
	"version": "0.0.1",
	"type": "module",
	"main": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"start": "bun run src/cli/run.ts",
		"build": "bun build src/index.ts --outdir dist",
		"typecheck": "tsc --noEmit",
		"format": "find src test -name '*.ts' -print0 | xargs -0 biome check --write --unsafe",
		"test": "vitest run"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"bulb": "git@github.com:CathodeCube/bulb.git",
		"lefthook": "^2.1.6",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"gray-matter": "^4.0.3",
		"zod": "^4.4.3"
	}
}
